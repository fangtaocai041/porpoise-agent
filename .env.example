# ============================================================
# Porpoise Agent 环境配置模板
# 复制此文件为 .env 并填写实际值
# ============================================================

# --- DeepSeek API (通过 Reasonix) ---
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# --- 默认模型选择 ---
# deepseek-chat (V3) 或 deepseek-reasoner (R1)
PORPOISE_DEFAULT_MODEL=deepseek-chat
PORPOISE_REASONING_MODEL=deepseek-reasoner

# --- 文献数据库 ---
# Semantic Scholar API (免费)
SEMANTIC_SCHOLAR_API_KEY=
# Europe PMC (免费，无需 key)
# Crossref (免费)
# arXiv (免费)

# --- 知识图谱 (可选) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# --- 向量数据库 ---
CHROMA_PERSIST_DIR=./data/chroma_db

# --- 数据目录 ---
PORPOISE_DATA_DIR=./data
PORPOISE_OUTPUT_DIR=./outputs

# --- 日志 ---
PORPOISE_LOG_LEVEL=INFO
PORPOISE_LOG_FILE=./logs/porpoise.log

# --- 课题组信息 ---
LAB_NAME=无锡渔业学院/淡水渔业研究中心 刘凯研究员课题组
LAB_SHORT=FFRC-LiuKai-Lab
LAB_EMAIL=liukai@ffrc.cn
